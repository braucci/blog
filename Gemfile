source "https://rubygems.org"

# GitHub Pages: assicura compatibilità con la versione di Jekyll
# effettivamente utilizzata dai server GitHub.
gem "github-pages", group: :jekyll_plugins

group :jekyll_plugins do
  gem "jekyll-feed"
  gem "jekyll-seo-tag"
  gem "jekyll-paginate"
  gem "jekyll-sitemap"
end

# Necessari su macOS recenti / Ruby >= 3.0
gem "webrick", "~> 1.8"
gem "tzinfo", "~> 2.0"
gem "tzinfo-data", platforms: [:mingw, :mswin, :x64_mingw, :jruby]
